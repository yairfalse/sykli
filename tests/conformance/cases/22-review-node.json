{
  "version": "1",
  "tasks": [
    {
      "name": "test",
      "command": "go test ./..."
    },
    {
      "name": "review-code",
      "kind": "review",
      "primitive": "lint",
      "agent": "claude",
      "context": ["src/**/*.go"],
      "depends_on": ["test"],
      "deterministic": true
    }
  ]
}
